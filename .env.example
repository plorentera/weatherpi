# WeatherPi Configuration
# Copy this file to .env and customize values

# ===== Core Configuration =====
APP_NAME=WeatherPi
APP_ENV=development
DEBUG=false

# ===== API Server =====
API_HOST=127.0.0.1
API_PORT=8000
API_LOG_LEVEL=INFO

# ===== Database =====
DATABASE_PATH=data/meteo.db

# ===== Authentication =====
# Reader role (read-only access)
WEATHERPI_READER_USER=reader
WEATHERPI_READER_PASS=reader
# Use WEATHERPI_READER_PASS_HASH for production (format: pbkdf2_sha256$iterations$salt$hash)
# WEATHERPI_READER_PASS_HASH=

# Admin role (full access)
WEATHERPI_ADMIN_USER=admin
WEATHERPI_ADMIN_PASS=admin
# Use WEATHERPI_ADMIN_PASS_HASH for production
# WEATHERPI_ADMIN_PASS_HASH=

# Session configuration
WEATHERPI_SESSION_SECRET=change-me-in-production-with-a-random-secret
WEATHERPI_SESSION_TTL_SECONDS=43200
WEATHERPI_COOKIE_SECURE=false
WEATHERPI_COOKIE_SAMESITE=lax

# ===== Collector Configuration =====
COLLECTOR_ENABLED=true
COLLECTOR_SAMPLE_INTERVAL_SECONDS=5
COLLECTOR_RETENTION_DAYS=7
COLLECTOR_LOG_LEVEL=INFO

# ===== Sensor Configuration =====
# Options: mock, dht22, bmp280, etc.
SENSOR_TYPE=mock

# ===== Output Configuration =====
# Webhook output
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_TIMEOUT_SECONDS=5

# MQTT output
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=meteo/measurements
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== Export/Backup Configuration =====
EXPORTS_ENABLED=false
EXPORTS_FREQUENCY=daily
EXPORTS_EVERY_DAYS=1
EXPORTS_KEEP_DAYS=30
EXPORTS_DAYS_PER_FILE=1
EXPORTS_SCHEDULE_TIME_LOCAL=01:00
EXPORTS_UPLOAD_ENABLED=false
EXPORTS_UPLOAD_WEBHOOK_URL=

# ===== Logging =====
LOG_FORMAT=json  # json or text
LOG_TO_FILE=false
LOG_FILE_PATH=logs/weatherpi.log

# ===== Feature Flags =====
FEATURE_PROMETHEUS_METRICS=false
FEATURE_HEALTH_CHECK=true
